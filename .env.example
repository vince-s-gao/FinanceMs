# 数据库配置
DATABASE_URL="postgresql://postgres:password@localhost:5432/inffinancems?schema=public"

# JWT配置
# ⚠️ 生产环境必须使用强随机密钥（至少32字节），可以使用以下命令生成：
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET="change-this-to-a-strong-random-secret-key-at-least-32-bytes-long"
JWT_EXPIRES_IN="2h"
JWT_REFRESH_EXPIRES_IN="30d"
# 兼容旧配置键（如已使用可保留）
JWT_REFRESH_TOKEN_EXPIRES_IN="30d"

# Seed 初始化账号密码（建议至少设置 SEED_DEFAULT_PASSWORD）
SEED_DEFAULT_PASSWORD=""
ADMIN_INITIAL_PASSWORD=""
FINANCE_INITIAL_PASSWORD=""
MANAGER_INITIAL_PASSWORD=""
EMPLOYEE_INITIAL_PASSWORD=""

# Redis配置（可选）
REDIS_URL="redis://localhost:6379"

# 应用配置
NODE_ENV="development"
API_PORT=3001
WEB_PORT=43001
FORCE_HTTPS="false"
NEXT_PUBLIC_FORCE_HTTPS="false"

# 飞书应用配置（在飞书开放平台创建应用后获取）
# https://open.feishu.cn/app
FEISHU_APP_ID="your-feishu-app-id"
FEISHU_APP_SECRET="your-feishu-app-secret"
FEISHU_REDIRECT_URI="http://localhost:3001/api/auth/feishu/callback"

# 前端URL（用于飞书回调重定向）
FRONTEND_URL="http://localhost:43001"

# CORS 白名单（逗号分隔）
CORS_ORIGIN="http://localhost:3000,http://localhost:43001"

# Next.js公共变量
NEXT_PUBLIC_API_URL="http://localhost:3001/api"
NEXT_PUBLIC_APP_NAME="InfFinanceMs"
NEXT_PUBLIC_FEISHU_ENABLED="true"
